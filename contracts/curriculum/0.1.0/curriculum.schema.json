{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repofluent.example/contracts/curriculum/0.1.0/curriculum.schema.json",
  "title": "RepoFluent Curriculum Package 0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "packageId",
    "version",
    "title",
    "description",
    "owner",
    "locale",
    "sourceSnapshot",
    "courses"
  ],
  "properties": {
    "contractVersion": { "const": "0.1.0" },
    "packageId": { "$ref": "#/$defs/identifier" },
    "version": { "type": "string", "minLength": 1, "maxLength": 40 },
    "title": { "type": "string", "minLength": 1, "maxLength": 240 },
    "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "owner": { "type": "string", "minLength": 1, "maxLength": 160 },
    "locale": { "type": "string", "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$" },
    "sourceSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repositories"],
      "properties": {
        "repositories": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/repository" }
        }
      }
    },
    "courses": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/course" }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "revision"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "revision": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "course": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "description",
        "difficulty",
        "estimatedMinutes",
        "objectives",
        "modules"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "difficulty": { "enum": ["foundational", "intermediate", "advanced"] },
        "estimatedMinutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "objectives": { "$ref": "#/$defs/objectives" },
        "modules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/module" }
        }
      }
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "lessons"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "lessons": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/lesson" }
        }
      }
    },
    "lesson": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "estimatedMinutes", "objectives", "blocks"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "estimatedMinutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "objectives": { "$ref": "#/$defs/objectives" },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/proseBlock" },
              { "$ref": "#/$defs/calloutBlock" },
              { "$ref": "#/$defs/codeReferenceBlock" }
            ]
          }
        }
      }
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "proseBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "text"],
      "properties": {
        "type": { "const": "prose" },
        "text": { "type": "string", "minLength": 1, "maxLength": 10000 }
      }
    },
    "calloutBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tone", "title", "text"],
      "properties": {
        "type": { "const": "callout" },
        "tone": { "enum": ["information", "warning"] },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "text": { "type": "string", "minLength": 1, "maxLength": 5000 }
      }
    },
    "codeReferenceBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "repositoryId",
        "path",
        "language",
        "startLine",
        "endLine",
        "symbol",
        "explanation"
      ],
      "properties": {
        "type": { "const": "codeReference" },
        "repositoryId": { "$ref": "#/$defs/identifier" },
        "path": { "type": "string", "minLength": 1, "maxLength": 500 },
        "language": { "enum": ["csharp", "typescript", "html", "scss"] },
        "startLine": { "type": "integer", "minimum": 1 },
        "endLine": { "type": "integer", "minimum": 1 },
        "symbol": { "type": "string", "minLength": 1, "maxLength": 300 },
        "explanation": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    }
  }
}
