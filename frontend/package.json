    "@angular/platform-browser": "21.2.18",
    "@angular/router": "21.2.18",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.19",
    "@angular/cli": "21.2.19",
    "@angular/compiler-cli": "21.2.18",
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "1.61.1",
    "jsdom": "28.0.0",
    "ng-packagr": "21.2.5",
    "prettier": "3.9.6",
    "typescript": "~5.9.2",
    "vitest": "4.1.10"
  },
  "overrides": {
