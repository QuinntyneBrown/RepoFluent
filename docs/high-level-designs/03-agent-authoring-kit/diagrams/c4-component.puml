@startuml
!include <C4/C4_Component>
LAYOUT_WITH_LEGEND()
title Components — Agent Authoring Kit

Person(actor, "Curriculum authoring agent", "Analyzes approved source material within a customer-controlled environment")
Container_Boundary(api, "RepoFluent.Api") {
  Component(kit_endpoint, "AuthoringKitDownloadEndpoint", "ASP.NET Core", "Lists compatible kit releases and returns signed download references")
}
Container_Boundary(tool, "Authoring and delivery environment") {
  Component(agent_guidance, "Agent Guidance Bundle", "Markdown and templates", "Constrains scope, provenance, uncertainty, secrets, and identifier behavior")
  Component(authoring_orchestrator, "Authoring Orchestrator", "Customer-selected agent", "Analyzes approved material and assembles a package")
  Component(local_validator, "RepoFluent.ContractCli", ".NET tool", "Validates generated bytes before they leave the approved environment")
  Component(manifest_writer, "GenerationManifestWriter", "Kit utility", "Records reproducible non-reasoning generation metadata")
}
ContainerDb(kit_registry, "Authoring kit registry", "Versioned artifact storage <TO SUPPLY>", "Stores immutable signed kit releases")
ContainerDb(workspace, "Approved authoring workspace", "Customer-controlled file system", "Holds approved sources and generated output")
System_Ext(sources, "Approved repositories and documents", "Provide the declared source snapshot under customer access policy")
System_Ext(agent_runtime, "Customer-selected agent runtime", "Executes the kit instructions inside the approved environment")

Rel(actor, authoring_orchestrator, "Runs as", "agent runtime")
Rel(kit_endpoint, kit_registry, "Reads immutable kit releases from", "artifact API")
Rel(authoring_orchestrator, kit_endpoint, "Downloads compatible kit from", "HTTPS")
Rel(authoring_orchestrator, agent_guidance, "Follows", "local files")
Rel(authoring_orchestrator, sources, "Reads declared snapshot from", "customer-controlled access")
Rel(authoring_orchestrator, workspace, "Writes generated package to", "file system")
Rel(manifest_writer, workspace, "Writes manifest and checksum to", "file system")
Rel(local_validator, workspace, "Reads and validates package in", "file system")
Rel(authoring_orchestrator, agent_runtime, "Executes within", "provider-specific")
@enduml
