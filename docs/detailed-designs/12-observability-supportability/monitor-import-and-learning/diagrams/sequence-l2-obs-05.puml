@startuml
title UML sequence behaviour — Learner rendering and performance monitoring
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
skinparam package {
  BorderColor #667085
  FontColor #101828
  BackgroundColor #F9FAFB
}
actor "Platform operator" as actor
box "Frontend — Operations console" #E0F2FE
  participant "MonitorImportAndLearningConsole" as entry
  participant "OperationsApiClient" as client
end box
box "Backend — Operations API application" #D1FADF
  participant "MonitorImportAndLearningController" as controller
end box
box "Backend — Observability and Supportability Application and Domain" #ECFDF3
  participant "MonitorImportAndLearningHandler" as handler
  participant "MonitorImportAndLearningPolicy" as policy
end box
box "Backend — Observability and Supportability Infrastructure" #FFF4E5
  participant "IMonitorImportAndLearningRepository" as repository
  database "Operational telemetry store" as store
end box
actor -> entry : Start monitor import and learning
entry -> client : Build typed request
client -> controller : Send request with scope and correlation
controller -> controller : Authenticate and apply endpoint policy
controller -> handler : Dispatch MonitorImportAndLearningRequest
handler -> repository : Load authorized current state
repository -> store : Read tenant-scoped record
store --> repository : Current record
repository --> handler : Authorized state
handler -> policy : Apply L2-OBS-05
alt Policy and validation accept the request
  policy --> handler : Typed accepted result
  handler -> repository : Save with expected version and idempotency key
  repository -> store : Commit one result
  store --> repository : Durable version
  repository --> handler : Commit result
  handler --> controller : Typed feature result
else Policy or validation rejects the request
  policy --> handler : Typed rejection without mutation
  handler --> controller : Safe failure result
end
controller --> client : HTTP response or Problem Details
client --> entry : Typed outcome
entry --> actor : Present accessible feature state
@enduml
