@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam class {
  BorderColor #344054
  FontColor #101828
  BackgroundColor #F9FAFB
}
title Class structure — Protect logs and errors

class ProtectLogsAndErrorsRequest {
  +string ScopeId
  +string ActorId
  +string TargetId
  +long ExpectedVersion
  +string CorrelationId
  +object Payload
}

class ProtectLogsAndErrorsResult {
  +string Outcome
  +long Version
  +string SupportId
}

class ProtectLogsAndErrorsRecord {
  +string Id
  +string TenantId
  +long Version
  +string Status
  +DateTimeOffset UpdatedAt
  +Apply(result: ProtectLogsAndErrorsResult): void
}

class ProtectLogsAndErrorsPolicy {
  +Evaluate(request: ProtectLogsAndErrorsRequest, current: ProtectLogsAndErrorsRecord): ProtectLogsAndErrorsResult
}

interface IProtectLogsAndErrorsRepository {
  +Load(scopeId: string, targetId: string): Task<ProtectLogsAndErrorsRecord>
  +Save(record: ProtectLogsAndErrorsRecord, expectedVersion: long): Task
}

class ProtectLogsAndErrorsHandler {
  +Handle(request: ProtectLogsAndErrorsRequest): Task<ProtectLogsAndErrorsResult>
}

ProtectLogsAndErrorsHandler ..> ProtectLogsAndErrorsRequest : handles
ProtectLogsAndErrorsHandler ..> ProtectLogsAndErrorsPolicy : invokes
ProtectLogsAndErrorsHandler ..> IProtectLogsAndErrorsRepository : uses
IProtectLogsAndErrorsRepository --> ProtectLogsAndErrorsRecord : loads / saves
ProtectLogsAndErrorsPolicy ..> ProtectLogsAndErrorsRecord : evaluates
ProtectLogsAndErrorsPolicy ..> ProtectLogsAndErrorsResult : creates
ProtectLogsAndErrorsRecord ..> ProtectLogsAndErrorsResult : applies
@enduml
