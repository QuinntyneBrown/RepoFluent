}

class RespondToIncidentsPolicy {
  +Evaluate(request: RespondToIncidentsRequest, current: RespondToIncidentsRecord): RespondToIncidentsResult
}

interface IRespondToIncidentsRepository {
  +Load(scopeId: string, targetId: string): Task<RespondToIncidentsRecord>
  +Save(record: RespondToIncidentsRecord, expectedVersion: long): Task
}

class RespondToIncidentsHandler {
  +Handle(request: RespondToIncidentsRequest): Task<RespondToIncidentsResult>
}

RespondToIncidentsHandler ..> RespondToIncidentsRequest : handles
RespondToIncidentsHandler ..> RespondToIncidentsPolicy : invokes
RespondToIncidentsHandler ..> IRespondToIncidentsRepository : uses
IRespondToIncidentsRepository --> RespondToIncidentsRecord : loads / saves
RespondToIncidentsPolicy ..> RespondToIncidentsRecord : evaluates
RespondToIncidentsPolicy ..> RespondToIncidentsResult : creates
RespondToIncidentsRecord ..> RespondToIncidentsResult : applies
