@startuml
title UML sequence behaviour — Processing and publication status
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
skinparam package {
  BorderColor #667085
  FontColor #101828
  BackgroundColor #F9FAFB
}
actor "Tenant administrator" as actor
box "Frontend — Administration application" #E0F2FE
  participant "AdministerCurriculaAndStatusPage" as entry
  participant "AdministrationApiClient" as client
end box
box "Backend — Administration API application" #D1FADF
  participant "AdministerCurriculaAndStatusController" as controller
end box
box "Backend — Administration and Tenant Operations Application and Domain" #ECFDF3
  participant "AdministerCurriculaAndStatusHandler" as handler
  participant "AdministerCurriculaAndStatusPolicy" as policy
end box
box "Backend — Administration and Tenant Operations Infrastructure" #FFF4E5
  participant "IAdministerCurriculaAndStatusRepository" as repository
  database "Tenant operations store" as store
end box
actor -> entry : Start administer curricula and status
entry -> client : Build typed request
client -> controller : Send request with scope and correlation
controller -> controller : Authenticate and apply endpoint policy
controller -> handler : Dispatch AdministerCurriculaAndStatusRequest
handler -> repository : Load authorized current state
repository -> store : Read tenant-scoped record
store --> repository : Current record
repository --> handler : Authorized state
handler -> policy : Apply L2-ATO-07
alt Policy and validation accept the request
  policy --> handler : Typed accepted result
  handler -> repository : Save with expected version and idempotency key
  repository -> store : Commit one result
  store --> repository : Durable version
  repository --> handler : Commit result
  handler --> controller : Typed feature result
else Policy or validation rejects the request
  policy --> handler : Typed rejection without mutation
  handler --> controller : Safe failure result
end
controller --> client : HTTP response or Problem Details
client --> entry : Typed outcome
entry --> actor : Present accessible feature state
@enduml
