@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Access support diagnostics

Person(actor, "Tenant administrator", "Operates authorized tenant configuration and workflows")
System_Boundary(repofluent, "RepoFluent") {
  Container(entry, "Administration application", "Angular 21", "Tenant administration interface")
  Container(api, "Administration API", "ASP.NET Core", "Applies application and domain policy")
  ContainerDb(store, "Tenant operations store", "<TO SUPPLY>", "Stores tenant-scoped state and evidence")
}
System_Ext(dependency, "Notification provider", "Delivers configured tenant notification channels")

Rel(actor, entry, "Uses", "HTTPS or local invocation")
Rel(entry, api, "Sends typed requests", "JSON/HTTPS or local contract")
Rel(api, store, "Reads and writes", "Application abstraction")
Rel(api, dependency, "Calls through approved adapter")
@enduml
