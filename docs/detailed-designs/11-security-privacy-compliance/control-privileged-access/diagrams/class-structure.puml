@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam class {
  BorderColor #344054
  FontColor #101828
  BackgroundColor #F9FAFB
}
title Class structure — Control privileged access

class ControlPrivilegedAccessRequest {
  +string ScopeId
  +string ActorId
  +string TargetId
  +long ExpectedVersion
  +string CorrelationId
  +object Payload
}

class ControlPrivilegedAccessResult {
  +string Outcome
  +long Version
  +string SupportId
}

class ControlPrivilegedAccessRecord {
  +string Id
  +string TenantId
  +long Version
  +string Status
  +DateTimeOffset UpdatedAt
  +Apply(result: ControlPrivilegedAccessResult): void
}

class ControlPrivilegedAccessPolicy {
  +Evaluate(request: ControlPrivilegedAccessRequest, current: ControlPrivilegedAccessRecord): ControlPrivilegedAccessResult
}

interface IControlPrivilegedAccessRepository {
  +Load(scopeId: string, targetId: string): Task<ControlPrivilegedAccessRecord>
  +Save(record: ControlPrivilegedAccessRecord, expectedVersion: long): Task
}

class ControlPrivilegedAccessHandler {
  +Handle(request: ControlPrivilegedAccessRequest): Task<ControlPrivilegedAccessResult>
}

ControlPrivilegedAccessHandler ..> ControlPrivilegedAccessRequest : handles
ControlPrivilegedAccessHandler ..> ControlPrivilegedAccessPolicy : invokes
ControlPrivilegedAccessHandler ..> IControlPrivilegedAccessRepository : uses
IControlPrivilegedAccessRepository --> ControlPrivilegedAccessRecord : loads / saves
ControlPrivilegedAccessPolicy ..> ControlPrivilegedAccessRecord : evaluates
ControlPrivilegedAccessPolicy ..> ControlPrivilegedAccessResult : creates
ControlPrivilegedAccessRecord ..> ControlPrivilegedAccessResult : applies
@enduml
