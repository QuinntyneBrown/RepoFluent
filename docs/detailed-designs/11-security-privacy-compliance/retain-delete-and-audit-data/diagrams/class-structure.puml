@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam class {
  BorderColor #344054
  FontColor #101828
  BackgroundColor #F9FAFB
}
title Class structure — Retain, delete, and audit data

class RetainDeleteAndAuditDataRequest {
  +string ScopeId
  +string ActorId
  +string TargetId
  +long ExpectedVersion
  +string CorrelationId
  +object Payload
}

class RetainDeleteAndAuditDataResult {
  +string Outcome
  +long Version
  +string SupportId
}

class RetainDeleteAndAuditDataRecord {
  +string Id
  +string TenantId
  +long Version
  +string Status
  +DateTimeOffset UpdatedAt
  +Apply(result: RetainDeleteAndAuditDataResult): void
}

class RetainDeleteAndAuditDataPolicy {
  +Evaluate(request: RetainDeleteAndAuditDataRequest, current: RetainDeleteAndAuditDataRecord): RetainDeleteAndAuditDataResult
}

interface IRetainDeleteAndAuditDataRepository {
  +Load(scopeId: string, targetId: string): Task<RetainDeleteAndAuditDataRecord>
  +Save(record: RetainDeleteAndAuditDataRecord, expectedVersion: long): Task
}

class RetainDeleteAndAuditDataHandler {
  +Handle(request: RetainDeleteAndAuditDataRequest): Task<RetainDeleteAndAuditDataResult>
}

RetainDeleteAndAuditDataHandler ..> RetainDeleteAndAuditDataRequest : handles
RetainDeleteAndAuditDataHandler ..> RetainDeleteAndAuditDataPolicy : invokes
RetainDeleteAndAuditDataHandler ..> IRetainDeleteAndAuditDataRepository : uses
IRetainDeleteAndAuditDataRepository --> RetainDeleteAndAuditDataRecord : loads / saves
RetainDeleteAndAuditDataPolicy ..> RetainDeleteAndAuditDataRecord : evaluates
RetainDeleteAndAuditDataPolicy ..> RetainDeleteAndAuditDataResult : creates
RetainDeleteAndAuditDataRecord ..> RetainDeleteAndAuditDataResult : applies
@enduml
