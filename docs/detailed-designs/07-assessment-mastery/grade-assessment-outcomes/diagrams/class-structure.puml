@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam class {
  BorderColor #344054
  FontColor #101828
  BackgroundColor #F9FAFB
}
title Class structure — Grade assessment outcomes

class GradeAssessmentOutcomesRequest {
  +string ScopeId
  +string ActorId
  +string TargetId
  +long ExpectedVersion
  +string CorrelationId
  +object Payload
}

class GradeAssessmentOutcomesResult {
  +string Outcome
  +long Version
  +string SupportId
}

class GradeAssessmentOutcomesRecord {
  +string Id
  +string TenantId
  +long Version
  +string Status
  +DateTimeOffset UpdatedAt
  +Apply(result: GradeAssessmentOutcomesResult): void
}

class GradeAssessmentOutcomesPolicy {
  +Evaluate(request: GradeAssessmentOutcomesRequest, current: GradeAssessmentOutcomesRecord): GradeAssessmentOutcomesResult
}

interface IGradeAssessmentOutcomesRepository {
  +Load(scopeId: string, targetId: string): Task<GradeAssessmentOutcomesRecord>
  +Save(record: GradeAssessmentOutcomesRecord, expectedVersion: long): Task
}

class GradeAssessmentOutcomesHandler {
  +Handle(request: GradeAssessmentOutcomesRequest): Task<GradeAssessmentOutcomesResult>
}

GradeAssessmentOutcomesHandler ..> GradeAssessmentOutcomesRequest : handles
GradeAssessmentOutcomesHandler ..> GradeAssessmentOutcomesPolicy : invokes
GradeAssessmentOutcomesHandler ..> IGradeAssessmentOutcomesRepository : uses
IGradeAssessmentOutcomesRepository --> GradeAssessmentOutcomesRecord : loads / saves
GradeAssessmentOutcomesPolicy ..> GradeAssessmentOutcomesRecord : evaluates
GradeAssessmentOutcomesPolicy ..> GradeAssessmentOutcomesResult : creates
GradeAssessmentOutcomesRecord ..> GradeAssessmentOutcomesResult : applies
@enduml
