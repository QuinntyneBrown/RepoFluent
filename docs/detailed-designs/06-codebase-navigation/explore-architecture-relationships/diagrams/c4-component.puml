Container_Boundary(api, "Code Navigation API") {
  Component(controller, "ExploreArchitectureRelationshipsController", "ASP.NET Core boundary", "Authenticates, authorizes, and dispatches the request")
  Component(handler, "ExploreArchitectureRelationshipsHandler", "Application handler", "Coordinates one feature result")
  Component(policy, "ExploreArchitectureRelationshipsPolicy", "Domain policy", "Enforces the cited L2 rules")
  Component(repository, "IExploreArchitectureRelationshipsRepository", "Application port", "Reads and writes tenant-scoped state")
