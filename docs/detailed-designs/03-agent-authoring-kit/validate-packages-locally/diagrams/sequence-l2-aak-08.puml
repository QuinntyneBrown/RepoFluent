@startuml
title UML sequence behaviour — Local validator interface
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
actor "Curriculum authoring agent" as agent
box "Frontend — Acquired authoring-kit command" #E0F2FE
  participant "validate.mjs" as command
end box
box "Backend — Agent Authoring Kit Application and Domain" #D1FADF
  participant "Option and contract selector" as selector
  participant "Schema and extension validator" as validator
  participant "Threshold and outcome projector" as projector
end box
box "Backend — Authoring-kit release Infrastructure" #FFF4E5
  collections "Package JSON" as package
  collections "curriculum.validator.mjs" as schema
end box

agent -> command : Validate package with options
command -> selector : Parse package, contract, format,\nand severity threshold
selector -> package : Read declared local package
package --> selector : Package bytes and contract version
selector -> schema : Load selected bundled contract
schema --> selector : Compiled validator
selector -> validator : Apply L2-AAK-08 contract validation
validator --> selector : Ordered schema and extension issues
selector -> projector : Filter issues and classify outcome
alt Valid without visible issues
  projector --> command : success and status 0
else Warnings without blocking issue
  projector --> command : warnings-only and status 3
else Blocking package issue
  projector --> command : validation-failure and status 1
else Invalid arguments or package path
  projector --> command : invalid-invocation and status 2
else Validator cannot initialize or complete
  projector --> command : internal-failure and status 4
end
command --> agent : Safe JSON or text report
@enduml
