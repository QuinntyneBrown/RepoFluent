@startuml
title UML sequence behaviour — Uncertainty report
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
actor "Curriculum authoring agent" as agent
box "Frontend — Acquired authoring-kit command" #E0F2FE
  participant "validate-evidence.mjs" as command
end box
box "Backend — Agent Authoring Kit Application and Domain" #D1FADF
  participant "Uncertainty validator" as uncertainty
  participant "Citation resolver" as citations
  participant "Report writer" as report
end box
box "Backend — Evidence report Infrastructure" #FFF4E5
  collections "Structured uncertainty report" as ledger
  database "Approved repository snapshot" as repository
end box

agent -> command : Validate evidence report
command -> ledger : Read confidence and uncertainty collections
ledger --> command : Assumptions, conflicts, missing context,\nomissions, and unresolved questions
command -> uncertainty : Apply L2-AAK-06
loop Every uncertainty entry
  uncertainty -> uncertainty : Check confidence, material decision,\nand related claim identifiers
  alt Entry is a conflict
    uncertainty -> citations : Require at least two citations
    citations -> repository : Verify each approved snapshot source
    repository --> citations : Source bytes
    citations --> uncertainty : Valid sources or safe findings
  end
  alt Entry is material and represented in package
    uncertainty -> report : Count visible package representation
  else Material entry lacks package representation
    uncertainty -> report : AAK_UNCERTAINTY_UNREPRESENTED\nat exact JSON path
  end
end
report --> command : Counts and safe findings
command --> agent : valid=true + exit 0
opt Blocking finding exists
  command --> agent : valid=false + exit 1
end
@enduml
