@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Cite sources and uncertainty

Person(agent, "Curriculum authoring agent", "Creates claims and structured uncertainty")
System_Boundary(repofluent, "RepoFluent authoring workflow") {
  Container(policyView, "Evidence-ledger policy view", "Angular", "Explains citations, classifications, and material uncertainty")
  Container(evidenceValidator, "Evidence validator", "Dependency-free Node.js 22 command", "Validates the evidence ledger and emits safe findings")
  Container(preflight, "Source-scope preflight", "Dependency-free Node.js 22 command", "Calculates approved effective files")
  ContainerDb(release, "Acquired authoring-kit release", "Versioned files", "Guide, reports, commands, and checksums")
}
System_Ext(scope, "Source-scope declaration", "Approved repositories, revisions, files, and data rules")
System_Ext(repository, "Approved repository snapshot", "Local source bytes for snapshot-bound citations")

Rel(agent, policyView, "Reviews policy")
Rel(agent, evidenceValidator, "Invokes", "Local process")
Rel(evidenceValidator, preflight, "Reruns before citation access")
Rel(evidenceValidator, release, "Reads guide and evidence report from")
Rel(preflight, scope, "Validates")
Rel(preflight, repository, "Calculates effective files from")
Rel(evidenceValidator, repository, "Hashes and locates admitted citations in")
Rel(evidenceValidator, agent, "Returns JSON and exit status", "Standard output")
@enduml
