@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Publish the authoring kit

Person(author, "Curriculum author", "Acquires and uses authoring-kit releases")
System_Boundary(repofluent, "RepoFluent") {
  Container(spa, "RepoFluent application", "Angular 21", "Presents release versions, offline policy, and artifacts")
  Container(api, "RepoFluent API", "ASP.NET Core 10", "Verifies and serves allow-listed release artifacts")
  Container(release, "Published authoring-kit releases", "Versioned files", "Stores manifests, instructions, contracts, examples, and local runtime")
}
System_Ext(workspace, "Acquired authoring workspace", "Node.js 22 runtime with no package dependencies")

Rel(author, spa, "Inspects a release", "HTTPS")
Rel(spa, api, "Gets release metadata", "JSON/HTTPS")
Rel(api, release, "Verifies and reads", "Local filesystem")
Rel(author, workspace, "Runs local commands in")
Rel(release, workspace, "Is acquired into")
@enduml
