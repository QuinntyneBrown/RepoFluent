@startuml
title UML sequence behaviour — Kit contents and release manifest
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
skinparam package {
  BorderColor #667085
  FontColor #101828
  BackgroundColor #F9FAFB
}
actor "Curriculum author" as author
box "Frontend — RepoFluent Angular application" #E0F2FE
  participant "AuthoringKitPageComponent" as page
  participant "RepoFluentApiService" as client
end box
box "Backend — RepoFluent API application" #D1FADF
  participant "AuthoringKitEndpoints" as endpoints
end box
box "Backend — Authoring Kit Application and Domain" #ECFDF3
  participant "AuthoringKitReleaseCatalog" as catalog
end box
box "Backend — Release filesystem Infrastructure" #FFF4E5
  database "Authoring-kit release directory" as files
end box

author -> page : Open authoring-kit release
page -> client : Request release 0.1.0
client -> endpoints : GET /api/authoring-kits/releases/0.1.0
endpoints -> catalog : GetRelease(version)
catalog -> files : Read manifest
files --> catalog : Version and artifact declarations
loop Every L2-AAK-01 artifact
  catalog -> files : Read allow-listed artifact bytes
  files --> catalog : Artifact bytes
  catalog -> catalog : Verify SHA-256 and safe release path
end
catalog -> catalog : Verify ordinal aggregate checksum
catalog --> endpoints : AuthoringKitReleaseView
endpoints --> client : 200 OK + release
client --> page : Typed release
page --> author : Present versions, offline policy, and inventory
@enduml
