@startuml
title UML sequence behaviour — Safe offline operation
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
skinparam package {
  BorderColor #667085
  FontColor #101828
  BackgroundColor #F9FAFB
}
actor "Curriculum author" as author
box "Frontend — Acquired authoring workspace" #E0F2FE
  participant "verify-release.mjs" as verifier
end box
box "Backend — Local Validator application" #D1FADF
  participant "validate.mjs" as command
end box
box "Backend — Bundled contract Application and Domain" #ECFDF3
  participant "curriculum.validator.mjs" as validator
end box
box "Backend — Acquired release Infrastructure" #FFF4E5
  database "Local release directory" as files
end box

author -> verifier : Verify acquired release
verifier -> files : Read manifest and every artifact
files --> verifier : Local bytes
verifier -> verifier : Apply L2-AAK-12 artifact and aggregate checksums
verifier --> author : Verified offline release
author -> command : Validate package.json
command -> files : Read local UTF-8 JSON
files --> command : Package data
command -> validator : Validate against compiled bundled schema
alt Package conforms
  validator --> command : valid true
  command --> author : Exit 0 with no issues
else Package does not conform
  validator --> command : Schema errors
  command --> author : Exit 1 with safe JSON Pointer issues
end
@enduml
