@startuml
title UML sequence behaviour — Generation manifest
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
actor "Curriculum authoring agent" as agent
box "Frontend — Acquired authoring-kit command" #E0F2FE
  participant "finalize-generation.mjs" as finalizer
end box
box "Backend — Agent Authoring Kit Application and Domain" #D1FADF
  participant "Run validator" as runValidator
  participant "validate.mjs" as packageValidator
  participant "Manifest projector" as projector
end box
box "Backend — Authoring workspace Infrastructure" #FFF4E5
  collections "Completed-run metadata" as run
  database "Generated package and bundled contract" as files
end box

agent -> finalizer : Finalize run and package
finalizer -> run : Read local metadata
run --> finalizer : Tool, model, versions, source,\ntime, inputs, and options
finalizer -> runValidator : Apply L2-AAK-11 required fields
runValidator --> finalizer : Accepted safe run fields
finalizer -> packageValidator : Validate package path offline
packageValidator -> files : Read package and bundled contract
files --> packageValidator : Local bytes
packageValidator --> finalizer : valid=true + zero issues
finalizer -> projector : Project allow-listed manifest
projector -> files : Hash exact package bytes
files --> projector : Package bytes
projector -> projector : Exclude reasoning, credentials,\nand full prompt transcripts
projector --> finalizer : Manifest with package SHA-256
finalizer --> agent : Manifest JSON + exit 0
@enduml
