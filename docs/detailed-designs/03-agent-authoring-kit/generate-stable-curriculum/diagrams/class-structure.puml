@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam class {
  BorderColor #344054
  FontColor #101828
  BackgroundColor #F9FAFB
}
title Information structure — Generate stable curriculum

class IdentityInput {
  +identityVersion: string
}

class IdentityNamespace {
  +organization: string
  +product: string
  +sourceScopeId: string
  +majorVersion: integer
}

class SemanticEntity {
  +kind: EntityKind
  +semanticKey: string
  +semanticFingerprint: string
  +title: string
}

enum EntityKind {
  package
  system
  course
  lesson
  objective
  code-reference
  assessment
}

class GeneratedIdentity {
  +kind: EntityKind
  +semanticKey: string
  +id: string
}

class CompletedGenerationRun {
  +manifestVersion: string
  +startedAt: timestamp
  +completedAt: timestamp
  +identityInput: string
  +evidenceReport: string
}

class ToolIdentity {
  +id: string
  +version: string
}

class SourceSnapshot {
  +scopeId: string
  +repositories: RepositoryRevision[]
}

class PackageReceipt {
  +path: string
  +sha256: string
}

class GenerationManifest {
  +manifestVersion: string
  +kitVersion: string
  +contractVersion: string
  +startedAt: timestamp
  +completedAt: timestamp
  +options: object
}

class ValidationSummary {
  +valid: boolean
  +issueCount: integer
}

IdentityInput "1" *-- "1" IdentityNamespace
IdentityInput "1" *-- "1..*" SemanticEntity
SemanticEntity --> EntityKind
GeneratedIdentity --> EntityKind
CompletedGenerationRun "1" *-- "1" ToolIdentity : tool
CompletedGenerationRun "1" o-- "0..1" ToolIdentity : model
CompletedGenerationRun "1" *-- "1" SourceSnapshot
GenerationManifest "1" *-- "1" ToolIdentity : tool
GenerationManifest "1" o-- "0..1" ToolIdentity : model
GenerationManifest "1" *-- "1" SourceSnapshot
GenerationManifest "1" *-- "1" PackageReceipt
GenerationManifest "1" *-- "1" ValidationSummary
@enduml
