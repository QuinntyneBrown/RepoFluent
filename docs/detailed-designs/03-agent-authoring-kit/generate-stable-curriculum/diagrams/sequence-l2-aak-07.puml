@startuml
title UML sequence behaviour — Deterministic identity procedure
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
actor "Curriculum authoring agent" as agent
box "Frontend — Acquired authoring-kit command" #E0F2FE
  participant "generate-identities.mjs" as command
end box
box "Backend — Agent Authoring Kit Application and Domain" #D1FADF
  participant "Namespace normalizer" as normalizer
  participant "Identity hasher" as hasher
  participant "Collision detector" as collision
end box
box "Backend — Authoring workspace Infrastructure" #FFF4E5
  collections "Semantic identity input" as input
end box

agent -> command : Generate stable identifiers
command -> input : Read namespace and semantic entities
input --> command : Stable inputs plus display titles
command -> normalizer : Apply L2-AAK-07 NFKC,\ncase, whitespace, and separators
normalizer --> command : Canonical namespace values
loop Every semantic entity
  command -> hasher : Hash namespace + kind + semantic key
  hasher --> command : Kind-prefixed stable identifier
  command -> collision : Compare identifier fingerprint
  alt Identifier is new or fingerprint matches
    collision --> command : Accepted generated identity
  else Distinct fingerprint shares identifier
    collision --> command : AAK_IDENTITY_COLLISION\nwithout overwrite
  end
end
command --> agent : Identities + safe findings + exit status
@enduml
