@startuml
title UML sequence behaviour — C# analysis guidance
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
actor "Curriculum authoring agent" as agent
box "Frontend — Acquired authoring-kit command" #E0F2FE
  participant "verify-ecosystem-analysis.mjs" as command
end box
box "Backend — Agent Authoring Kit Application and Domain" #D1FADF
  participant "C# coverage validator" as coverage
  participant "Path and source resolver" as resolver
  participant "Uncertainty validator" as uncertainty
end box
box "Backend — Authoring-kit release Infrastructure" #FFF4E5
  collections "C# analysis report" as report
  collections "Approved C# snapshot" as source
end box

agent -> command : Verify C# analysis report
command -> report : Read structured local report
report --> command : Eleven categories and unresolved behavior
command -> coverage : Apply L2-AAK-09 category profile
coverage --> command : Complete category set
loop Every category citation
  command -> resolver : Confine path and resolve locator
  resolver -> source : Read cited inert file
  source --> resolver : Supplied source bytes
  resolver --> command : Resolved evidence
end
command -> uncertainty : Validate dynamic registration finding
uncertainty --> command : Explicit unresolved behavior retained
command --> agent : Safe coverage summary and status
@enduml
