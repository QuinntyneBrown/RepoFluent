@startuml
title UML sequence behaviour — Angular analysis guidance
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
actor "Curriculum authoring agent" as agent
box "Frontend — Acquired authoring-kit command" #E0F2FE
  participant "verify-ecosystem-analysis.mjs" as command
end box
box "Backend — Agent Authoring Kit Application and Domain" #D1FADF
  participant "Angular coverage validator" as coverage
  participant "Path and source resolver" as resolver
  participant "User-flow validator" as flow
end box
box "Backend — Authoring-kit release Infrastructure" #FFF4E5
  collections "Angular analysis report" as report
  collections "Approved Angular snapshot" as source
end box

agent -> command : Verify Angular analysis report
command -> report : Read structured local report
report --> command : Eleven categories and five flow steps
command -> coverage : Apply L2-AAK-10 category profile
coverage --> command : Complete category set
loop Every category and flow citation
  command -> resolver : Confine path and resolve locator
  resolver -> source : Read cited inert file
  alt Supplied source exists
    source --> resolver : Local source bytes
    resolver --> command : Resolved evidence
  else Source step is absent
    source --> resolver : File not found
    resolver --> command : AAK_ANALYSIS_SOURCE_MISSING
  end
end
command -> flow : Validate route-to-API ordering
flow --> command : Five source-supported steps
command --> agent : Safe coverage summary and status
@enduml
