@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Analyze .NET and Angular

Person(agent, "Curriculum authoring agent", "Produces source-grounded ecosystem reports")
System_Boundary(repofluent, "RepoFluent authoring workflow") {
  Container(policyView, "Ecosystem policy view", "Angular", "Explains profile coverage and evidence gates")
  Container(verifier, "Ecosystem analysis verifier", "Dependency-free Node.js 22 command", "Validates profile coverage and resolves cited files")
  ContainerDb(release, "Acquired authoring-kit release", "Versioned files", "Stores guides, reports, fixture snapshots, command, and checksums")
}
System_Ext(dotnet, "Approved C# snapshot", "Solution and source files")
System_Ext(angular, "Approved Angular snapshot", "Application and source files")

Rel(agent, policyView, "Reviews profile contract")
Rel(agent, verifier, "Verifies report", "Local process")
Rel(verifier, release, "Runs from verified")
Rel(verifier, dotnet, "Reads cited local files from")
Rel(verifier, angular, "Reads cited local files from")
Rel(verifier, agent, "Returns safe summary", "Standard output")
@enduml
