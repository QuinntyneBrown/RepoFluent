@startuml
title UML sequence behaviour — Secret and sensitive-data handling
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
actor "Curriculum authoring agent" as agent
box "Frontend — Acquired authoring-kit command" #E0F2FE
  participant "preflight.mjs" as command
end box
box "Backend — Agent Authoring Kit Application and Domain" #D1FADF
  participant "Safe-text reader" as reader
  participant "Secret-pattern scanner" as scanner
  participant "Report writer" as report
end box
box "Backend — Approved repository Infrastructure" #FFF4E5
  database "Approved repository snapshot" as repository
end box

agent -> command : Run preflight before source analysis
command -> command : Calculate effective file paths
loop Effective file
  command -> reader : Read at most 1 MiB
  reader -> repository : Read local bytes
  repository --> reader : Bytes
  alt Binary or oversized file
    reader --> command : Not scannable; no content returned
  else Safe text
    reader --> scanner : Text in memory
    scanner -> scanner : Apply L2-AAK-04 credential patterns
    alt Suspected credential
      scanner -> report : AAK_SECRET_SUSPECTED,\nfile path, blocking=true
      note right of report
        Matched value is never
        added to the report.
      end note
    else No suspected credential
      scanner --> command : Clear
    end
  end
end
alt Any blocking finding exists
  report --> command : valid=false
  command --> agent : Redacted JSON + exit 1
else Scan is clear
  report --> command : valid=true
  command --> agent : Safe JSON + exit 0
end
@enduml
