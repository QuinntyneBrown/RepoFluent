@startuml
title UML sequence behaviour — Scope and access declaration
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
actor "Curriculum authoring agent" as agent
box "Frontend — Acquired authoring-kit command" #E0F2FE
  participant "preflight.mjs" as command
end box
box "Backend — Agent Authoring Kit Application and Domain" #D1FADF
  participant "Declaration validator" as validator
  participant "Canonical file walker" as walker
  participant "Report writer" as report
end box
box "Backend — Approved source Infrastructure" #FFF4E5
  collections "Source-scope declaration" as scope
  database "Approved repository snapshot" as repository
end box

agent -> command : Run preflight before analysis
command -> scope : Read local JSON
scope --> command : Repositories, revisions, documents,\ninclude/exclude, output, and data rules
command -> validator : Apply L2-AAK-03 and validate\nrequired declaration
alt Declaration is incomplete or unsafe
  validator -> report : Add blocking scope finding
  report --> command : valid=false
  command --> agent : Redacted JSON + exit 1
else Declaration is complete
  validator --> command : Accepted declaration
  command -> walker : Resolve each declared root
  walker -> repository : realpath + lstat + sorted readdir
  alt Root unavailable or symbolic link encountered
    walker -> report : Add blocking path-safe finding
  else Regular files discovered
    walker --> command : Candidate file paths
    command -> command : Apply include, exclude,\nand directory guidance
    command -> command : Require declared documents\nto remain effective
    command -> report : Record revision and effective paths
  end
  report --> command : Final report
  command --> agent : JSON + status 0 or 1
end
@enduml
