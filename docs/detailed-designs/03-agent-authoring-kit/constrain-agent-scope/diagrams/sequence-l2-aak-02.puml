@startuml
title UML sequence behaviour — Repository instruction precedence
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
actor "Curriculum authoring agent" as agent
box "Frontend — Acquired authoring-kit command" #E0F2FE
  participant "preflight.mjs" as command
end box
box "Backend — Agent Authoring Kit Application and Domain" #D1FADF
  participant "Canonical file walker" as walker
  participant "Guidance resolver" as guidance
  participant "Report writer" as report
end box
box "Backend — Approved repository Infrastructure" #FFF4E5
  database "Approved repository snapshot" as repository
end box

agent -> command : Run preflight with approved scope
command -> walker : Walk canonical repository root
walker -> repository : List regular files without following links
repository --> walker : AGENTS.md and candidate file paths
walker --> command : Sorted paths
command -> guidance : Apply L2-AAK-02 and order\nAGENTS.md root to directory
loop Applicable guidance file
  guidance -> repository : Read fenced repofluent-policy
  repository --> guidance : allow/deny and exclusions
end
loop Candidate file in declared include scope
  guidance -> guidance : Apply parent then directory policy
  alt Explicit or guidance exclusion applies
    guidance -> report : Record path, guidance, and safe reason
  else File remains admitted
    guidance -> report : Add effective file path
  end
end
report --> command : Safe repository report
command --> agent : valid=true + guidance order + exclusions
@enduml
