@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam class {
  BorderColor #344054
  FontColor #101828
  BackgroundColor #F9FAFB
}
title Information structure — Constrain agent scope

class SourceScopeDeclaration {
  +scopeVersion: string
  +scopeId: string
  +outputLocation: string
}

class RepositoryScope {
  +id: string
  +root: string
  +revision: string
  +documents: string[]
  +include: string[]
  +exclude: string[]
}

class DataHandling {
  +classification: string
  +excerptPolicy: "minimum-necessary"
  +redact: string[]
  +secretScanning: true
}

class GuidancePolicy {
  +path: string
  +directory: string
  +analysis: "allow" | "deny"
  +exclude: string[]
}

class PreflightReport {
  +valid: boolean
  +scopeId: string
  +outputLocation: string
}

class RepositoryReport {
  +id: string
  +revision: string
  +guidanceOrder: string[]
  +effectiveFiles: string[]
  +exclusions: Exclusion[]
}

class Exclusion {
  +path: string
  +guidance: string
  +reason: string
}

class Finding {
  +code: string
  +severity: "error"
  +isBlocking: true
  +path: string
  +message: string
}

SourceScopeDeclaration "1" *-- "1..*" RepositoryScope
SourceScopeDeclaration "1" *-- "1" DataHandling
PreflightReport "1" *-- "0..*" RepositoryReport
PreflightReport "1" *-- "0..*" Finding
RepositoryReport "1" *-- "0..*" Exclusion
RepositoryScope ..> GuidancePolicy : resolves for files
@enduml
