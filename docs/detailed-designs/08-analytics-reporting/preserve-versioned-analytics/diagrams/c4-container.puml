@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Preserve versioned analytics

Person(actor, "Authorized analytics user", "Inspects learner or population measures within granted scope")
System_Boundary(repofluent, "RepoFluent") {
  Container(entry, "Analytics application", "Angular 21", "Learner, manager, and reviewer analytics interface")
  Container(api, "Analytics API", "ASP.NET Core", "Applies application and domain policy")
  ContainerDb(store, "Analytics store", "<TO SUPPLY>", "Stores tenant-scoped state and evidence")
}
System_Ext(dependency, "Export delivery service", "Delivers expiring authorized report artifacts")

Rel(actor, entry, "Uses", "HTTPS or local invocation")
Rel(entry, api, "Sends typed requests", "JSON/HTTPS or local contract")
Rel(api, store, "Reads and writes", "Application abstraction")
Rel(api, dependency, "Calls through approved adapter")
@enduml
