@startuml
title UML sequence behaviour — Exact review decision
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
actor "Curriculum reviewer" as reviewer
box "Frontend — Curriculum workspace" #E0F2FE
  participant "CurriculumPageComponent" as page
  participant "RepoFluentApiService" as client
end box
box "Backend — Curriculum API" #D1FADF
  participant "CurriculumEndpoints" as endpoints
end box
box "Backend — Curriculum Lifecycle Application and Domain" #ECFDF3
  participant "CurriculumWorkflow" as workflow
  participant "CurriculumLifecycle" as lifecycle
  entity "ReviewDecision" as decision
end box
box "Backend — Curriculum Lifecycle Infrastructure" #FFF4E5
  participant "ICurriculumStore" as port
  database "SQLite curriculum store" as store
end box

reviewer -> page : Enter rationale and select decision
page -> client : Send decision with package and issue checksums
client -> endpoints : POST /api/curriculum-drafts/{id}/review-decisions
endpoints -> workflow : ReviewAsync Reviewer actor and request
workflow -> port : Load tenant lifecycle record
port -> store : Read draft, report, acknowledgement, and decision
store --> port : Current lifecycle row
port --> workflow : Exact review state
workflow -> workflow : Apply L2-CLI-07 role, checksum, report, warning, and rationale gates

alt First valid decision
  workflow -> lifecycle : Review with explicit Reviewer grant
  lifecycle --> workflow : Approved or Rejected status
  workflow -> decision : Create immutable evidence
  decision --> workflow : Tenant and exact checksums bound
  workflow -> port : Save status, decision, and audit
  port -> store : Commit one lifecycle transaction
  store --> port : Durable immutable result
  port --> workflow : Saved decision
  workflow --> endpoints : ImportStatus with ReviewDecision
  endpoints --> client : 200 exact evidence
  client --> page : Stored review result
  page --> reviewer : Decision evidence card
else Stale package or validation checksum
  workflow --> endpoints : CLI_STALE_CHECKSUM or CLI_STALE_VALIDATION_REPORT
  endpoints --> client : 409 Problem Details
  client --> page : Refresh guidance
  page --> reviewer : No decision recorded
else Rejection has no rationale
  workflow --> endpoints : CLI_REVIEW_RATIONALE_REQUIRED
  endpoints --> client : 400 Problem Details
  client --> page : Rationale guidance
  page --> reviewer : Draft remains reviewable
else Decision already exists
  port -> store : Attempt concurrency-token update
  store --> port : Existing decision or zero updated rows
  port --> workflow : ConcurrentReviewDecisionException
  workflow --> endpoints : CLI_REVIEW_DECISION_IMMUTABLE
  endpoints --> client : 409 Problem Details
  client --> page : Existing decision remains
  page --> reviewer : No replacement permitted
end
@enduml
