@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Preview and review a draft

Person(reviewer, "Curriculum reviewer", "Inspects protected draft content and records a decision")
System_Boundary(repofluent, "RepoFluent") {
  Container(web, "Curriculum workspace", "Angular 21", "Uses the production lesson renderer and presents decision evidence")
  Container(api, "RepoFluent API", "ASP.NET Core on .NET 10", "Authorizes preview and binds one decision to exact checksums")
  ContainerDb(store, "Curriculum store", "SQLite through EF Core", "Stores lifecycle state, validation evidence, acknowledgement, decision, and audit")
}

Rel(reviewer, web, "Previews and reviews draft", "HTTPS")
Rel(web, api, "Reads preview and submits exact decision", "JSON over HTTPS")
Rel(api, store, "Loads draft and commits immutable evidence", "EF Core")
@enduml
