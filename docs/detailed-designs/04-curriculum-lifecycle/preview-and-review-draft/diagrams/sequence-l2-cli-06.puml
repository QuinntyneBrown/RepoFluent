@startuml
title UML sequence behaviour — Learner-equivalent preview
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
actor "Authorized review participant" as reviewParticipant
box "Frontend — Curriculum workspace" #E0F2FE
  participant "CurriculumPageComponent" as page
  participant "LessonRendererComponent" as renderer
  participant "RepoFluentApiService" as client
end box
box "Backend — Curriculum API" #D1FADF
  participant "CurriculumEndpoints" as endpoints
end box
box "Backend — Curriculum Lifecycle Application and Domain" #ECFDF3
  participant "CurriculumWorkflow" as workflow
  participant "PackagePresenter" as presenter
end box
box "Backend — Curriculum Lifecycle Infrastructure" #FFF4E5
  participant "ICurriculumStore" as port
  database "SQLite curriculum store" as store
end box

reviewParticipant -> page : Select Preview draft
page -> client : Request current import preview
client -> endpoints : GET /api/curriculum-drafts/{id}/preview
endpoints -> workflow : GetPreviewAsync authorized actor
workflow -> workflow : Apply L2-CLI-06 role and Draft or Approved gate
workflow -> port : Load tenant lifecycle record
port -> store : Read draft, validation report, and package
store --> port : Authorized lifecycle row
port --> workflow : Exact draft evidence
workflow -> presenter : Remove protected answer values
presenter --> workflow : Review-safe package
workflow --> endpoints : Preview with package and issue checksums
endpoints --> client : 200 typed preview
client --> page : Protected package and draft evidence
page -> renderer : Render first lesson through production component
renderer --> page : Responsive content and shared fallbacks
page --> reviewParticipant : Draft version, safeguards, and lesson

note over workflow,store
  Preview performs no assignment,
  progress, or assessment write.
end note

alt Learner or unauthorized actor
  endpoints -> workflow : GetPreviewAsync unauthorized actor
  workflow --> endpoints : IAM_ROLE_REQUIRED
  endpoints --> client : 403 Problem Details
  client --> page : Safe access error
  page --> reviewParticipant : No draft content
end
@enduml
