@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Import a draft idempotently

Person(author, "Curriculum author", "Uploads approved curriculum JSON")
System_Boundary(repofluent, "RepoFluent") {
  Container(web, "Curriculum workspace", "Angular 21", "Shows package identity, platform draft, attempts, and replay state")
  Container(api, "RepoFluent API", "ASP.NET Core on .NET 10", "Resolves receipt replay or version conflict")
  Container(worker, "Curriculum validation hosted service", ".NET background service", "Retries claimed validation and commits complete outcomes")
  ContainerDb(store, "Curriculum store", "SQLite through EF Core", "Enforces tenant package-version uniqueness and stores lifecycle evidence")
}

Rel(author, web, "Uploads package", "HTTPS")
Rel(web, api, "Sends multipart intake and status queries", "HTTPS")
Rel(api, store, "Resolves or creates receipt", "EF Core")
Rel(worker, store, "Claims retryable records and commits draft", "EF Core")
@enduml
