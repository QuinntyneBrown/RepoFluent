@startuml
title UML sequence behaviour — Controlled publication
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
actor "Curriculum administrator" as admin
box "Frontend — Curriculum workspace" #E0F2FE
  participant "CurriculumPageComponent" as page
  participant "RepoFluentApiService" as client
end box
box "Backend — Curriculum API" #D1FADF
  participant "CurriculumEndpoints" as endpoints
end box
box "Backend — Curriculum Lifecycle Application and Domain" #ECFDF3
  participant "CurriculumWorkflow" as workflow
  participant "CurriculumLifecycle" as lifecycle
  entity "Publication" as publication
end box
box "Backend — Curriculum Lifecycle Infrastructure" #FFF4E5
  participant "ICurriculumStore" as port
  database "SQLite curriculum store" as store
end box

admin -> page : Select Publish version twice
page -> client : Submit duplicate publication commands
client -> endpoints : POST /api/curriculum-drafts/{id}/publish
endpoints -> workflow : PublishAsync Administrator actor
workflow -> port : Load tenant approved record
port -> store : Read decision, report, and publication token
store --> port : Approved lifecycle row
port --> workflow : Exact approval evidence
workflow -> workflow : Apply L2-CLI-08 role and unchanged checksum gates

par First publication command
  workflow -> lifecycle : Publish new version identity
  lifecycle --> workflow : Published status
  workflow -> publication : Bind ActiveForAssignment and event identity
  publication --> workflow : Immutable publication
  workflow -> port : Save lifecycle, publication, audit, and event
  port -> store : Commit one SaveChanges transaction
  store --> port : Durable publication
  port --> workflow : Winning result
and Concurrent publication command
  workflow -> lifecycle : Publish competing version identity
  lifecycle --> workflow : Competing Published state
  workflow -> port : Save with original null token
  port -> store : Conditional concurrency-token update
  store --> port : Zero rows updated
  port --> workflow : ConcurrentPublicationException
  workflow -> port : Reload winning publication
  port -> store : Read committed row
  store --> port : Winning version and event
  port --> workflow : Converged result
end

workflow --> endpoints : Same ImportStatus outcome
endpoints --> client : 200 active publication
client --> page : Version, checksum, policy, and event
page --> admin : Publication evidence card
@enduml
