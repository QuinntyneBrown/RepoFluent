@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam class {
  BorderColor #344054
  FontColor #101828
  BackgroundColor #F9FAFB
}
title Class structure — Publish an immutable version

class CurriculumWorkflow {
  +PublishAsync(actor, id): Task<ImportStatus>
  +AssignAsync(actor, request, correlationId): Task<Assignment>
  +GetLessonAsync(actor, versionId, courseId, lessonId): Task<LessonView>
}

class Publication {
  +Guid VersionId
  +string TenantId
  +Guid ImportId
  +string PackageId
  +string PackageVersion
  +string PackageChecksum
  +string AvailabilityPolicy
  +string PublishedBy
  +DateTimeOffset PublishedAt
  +Guid EventId
}

class CurriculumRecord {
  +Guid Id
  +string Checksum
  +CurriculumStatus Status
  +Guid? PublishedVersionId
  +ReviewDecision? ReviewDecision
  +Publication? Publication
}

class DomainEventEntity {
  +Guid Id
  +string TenantId
  +string EventType
  +Guid AggregateId
  +string PayloadJson
  +DateTimeOffset OccurredAt
}

class AssignmentRecord {
  +Guid PublishedVersionId
  +string LearnerId
}

class CurriculumLifecycle {
  +Publish(publishedVersionId): Guid
}

interface ICurriculumStore {
  +GetImportAsync(tenantId, id): Task<CurriculumRecord?>
  +SaveImportAsync(record, action, actorId): Task
  +GetPublishedAsync(tenantId, versionId): Task<CurriculumRecord?>
}

class CurriculumStore
class ConcurrentPublicationException

CurriculumWorkflow ..> Publication : creates and returns
CurriculumWorkflow --> CurriculumLifecycle : transitions through
CurriculumWorkflow --> ICurriculumStore : loads and saves through
ICurriculumStore <|.. CurriculumStore
CurriculumStore ..> ConcurrentPublicationException : raises on token race
CurriculumWorkflow ..> ConcurrentPublicationException : converges
CurriculumRecord *-- "0..1" Publication
Publication ..> DomainEventEntity : serialized into
AssignmentRecord --> Publication : identifies version
ICurriculumStore --> CurriculumRecord : stores
@enduml
