@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Publish an immutable version

Person(admin, "Curriculum administrator", "Publishes an approved checksum")
Person(learner, "Learner", "Reads version-bound assignments")
System_Boundary(repofluent, "RepoFluent") {
  Container(web, "Curriculum workspace", "Angular 21", "Presents immutable publication and outbox evidence")
  Container(api, "RepoFluent API", "ASP.NET Core on .NET 10", "Validates approval and converges publication commands")
  ContainerDb(store, "Curriculum store", "SQLite through EF Core", "Stores versions, publication concurrency token, audit, assignments, and outbox events")
}

Rel(admin, web, "Publishes approved draft", "HTTPS")
Rel(web, api, "Submits publication and reads evidence", "JSON over HTTPS")
Rel(api, store, "Commits publication and reads version-bound content", "EF Core")
Rel(learner, api, "Reads assigned immutable version", "HTTPS")
@enduml
