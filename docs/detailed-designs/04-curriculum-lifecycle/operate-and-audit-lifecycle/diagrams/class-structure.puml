@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam class {
  BorderColor #344054
  FontColor #101828
  BackgroundColor #F9FAFB
}
title Class structure — Operate and audit the lifecycle

class CurriculumPageComponent {
  +openHistory(): Promise<void>
  +retryValidation(): Promise<void>
  +auditLabel(action: string): string
}

class RepoFluentApiService {
  +getImport(id: string): Observable<ImportStatus>
  +getLifecycleHistory(id: string): Observable<LifecycleHistory>
  +retryValidation(id: string): Observable<ImportStatus>
}

class ImportStatus {
  +Guid Id
  +CurriculumStatus Status
  +string CorrelationId
  +IReadOnlyList<string> AllowedActions
  +LifecycleProgress Progress
}

class LifecycleProgress {
  +string ActiveStage
  +IReadOnlyList<string> CompletedStages
  +DateTimeOffset CreatedAt
  +DateTimeOffset? ProcessingStartedAt
  +DateTimeOffset? ValidationCompletedAt
  +bool IsStale
  +bool IsActionRequired
  +string? FailureCode
  +string? FailureDetail
}

class LifecycleHistory {
  +Guid ImportId
  +string PackageVersion
  +string PackageChecksum
  +CurriculumStatus CurrentStatus
  +string CorrelationId
  +IReadOnlyList<LifecycleAuditEntry> Entries
}

class LifecycleAuditEntry {
  +long Id
  +string Action
  +string ActorId
  +DateTimeOffset OccurredAt
  +string CorrelationId
  +string? PackageChecksum
  +string? PackageVersion
  +string? LifecycleStatus
}

class CurriculumWorkflow {
  +TimeSpan StaleValidationThreshold
  +GetStatusAsync(actor, id): Task<ImportStatus>
  +RetryValidationAsync(actor, id): Task<ImportStatus>
  +GetHistoryAsync(actor, id): Task<LifecycleHistory>
}

class CurriculumLifecycle {
  +CurriculumStatus Status
  +RecoverValidation(): void
}

interface ICurriculumStore {
  +ClaimReceivedAsync(): Task<CurriculumRecord?>
  +SaveImportAsync(record, action, actor): Task
  +GetLifecycleAuditAsync(tenantId, importId): Task<IReadOnlyList<LifecycleAuditEntry>>
}

class CurriculumStore {
  +ClaimReceivedAsync(): Task<CurriculumRecord?>
  +SaveImportAsync(record, action, actor): Task
  +GetLifecycleAuditAsync(tenantId, importId): Task<IReadOnlyList<LifecycleAuditEntry>>
}

CurriculumPageComponent ..> RepoFluentApiService : uses
RepoFluentApiService ..> ImportStatus : returns
RepoFluentApiService ..> LifecycleHistory : returns
ImportStatus *-- LifecycleProgress : owns
LifecycleHistory "1" *-- "*" LifecycleAuditEntry : orders
CurriculumWorkflow ..> ImportStatus : creates
CurriculumWorkflow ..> LifecycleHistory : creates
CurriculumWorkflow ..> CurriculumLifecycle : applies
CurriculumWorkflow ..> ICurriculumStore : uses
ICurriculumStore <|.. CurriculumStore : implements
CurriculumStore ..> LifecycleAuditEntry : reads
@enduml
