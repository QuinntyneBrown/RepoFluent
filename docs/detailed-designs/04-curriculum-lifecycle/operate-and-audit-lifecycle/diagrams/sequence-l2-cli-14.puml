@startuml
title UML sequence behaviour — Lifecycle audit trail
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
skinparam package {
  BorderColor #667085
  FontColor #101828
  BackgroundColor #F9FAFB
}
actor "Lifecycle actor or system" as lifecycleActor
actor "Auditor" as auditor
box "Frontend — RepoFluent Angular application" #E0F2FE
  participant "CurriculumPageComponent" as page
  participant "RepoFluentApiService" as client
end box
box "Backend — RepoFluent API application" #D1FADF
  participant "CurriculumEndpoints" as endpoints
end box
box "Backend — RepoFluent Application and Domain" #ECFDF3
  participant "CurriculumWorkflow" as workflow
end box
box "Backend — RepoFluent Infrastructure" #FFF4E5
  participant "CurriculumStore" as repository
  database "RepoFluent database" as db
end box

loop Upload through retirement
  lifecycleActor -> endpoints : Submit authorized lifecycle command
  endpoints -> workflow : Apply role, tenant, and transition policy
  workflow -> repository : Save state with L2-CLI-14 action and evidence
  repository -> db : Commit state, actor/system, version, checksum, time, correlation
  db --> repository : Append-only audit identifier
  repository --> workflow : Commit result
  workflow --> endpoints : Typed lifecycle result
  endpoints --> lifecycleActor : HTTP result
end

auditor -> page : Inspect lifecycle history
page -> client : getLifecycleHistory(importId)
client -> endpoints : GET /api/curriculum-imports/{id}/history
endpoints -> endpoints : Authenticate Auditor
endpoints -> workflow : GetHistoryAsync(actor, importId)
workflow -> repository : GetImportAsync(tenantId, importId)
repository -> db : Read tenant-scoped import
db --> repository : Current package identity and state
repository --> workflow : CurriculumRecord
workflow -> repository : GetLifecycleAuditAsync(tenantId, importId)
repository -> db : Read matching audit rows ordered by Id
db --> repository : Immutable ordered rows
repository --> workflow : LifecycleAuditEntry list
workflow --> endpoints : LifecycleHistory
endpoints --> client : 200 ordered evidence
client --> page : Render action, actor, state, time, and correlation
page --> auditor : Present lifecycle audit evidence
@enduml
