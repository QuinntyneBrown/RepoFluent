@startuml
title UML sequence behaviour — Authorized upload intake
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
actor "Curriculum author" as author
box "Frontend — Curriculum workspace" #E0F2FE
  participant "CurriculumPageComponent" as page
  participant "RepoFluentApiService" as client
end box
box "Backend — Curriculum API" #D1FADF
  participant "CurriculumEndpoints" as endpoints
end box
box "Backend — Curriculum Lifecycle Application and Domain" #ECFDF3
  participant "CurriculumWorkflow" as workflow
  participant "PackageIntakeScanner" as scanner
end box
box "Backend — Curriculum Lifecycle Infrastructure" #FFF4E5
  participant "ICurriculumStore" as port
  database "SQLite curriculum store" as store
end box

author -> page : Select approved JSON package
page -> client : Upload multipart file
client -> endpoints : POST /api/curriculum-imports
endpoints -> endpoints : Resolve authenticated tenant and author
endpoints -> workflow : Receive bytes and correlation identifier
workflow -> workflow : Apply L2-CLI-01 role, media, and size gates
workflow -> scanner : Read inert UTF-8 JSON object
scanner --> workflow : Safe raw package
workflow -> workflow : Compute SHA-256 and opaque import identifier
workflow -> port : Add tenant-scoped Received record
port -> store : Insert receipt and audit event
store --> port : Durable commit
port --> workflow : Receipt persisted
workflow --> endpoints : ImportReceipt with status location
endpoints --> client : 202 Accepted
client --> page : Typed receipt
page --> author : Show queued validation state
@enduml
