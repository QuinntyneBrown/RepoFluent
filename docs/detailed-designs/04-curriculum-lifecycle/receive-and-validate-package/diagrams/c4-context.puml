@startuml
!include <C4/C4_Context>
LAYOUT_WITH_LEGEND()
title System Context — Receive and validate a package

Person(author, "Curriculum author", "Uploads an approved curriculum package and reviews safe validation results")
Person(reviewer, "Curriculum reviewer", "Acknowledges an exact warning set and approves the bound checksum")
System(repofluent, "RepoFluent", "Accepts inert package bytes, validates the curriculum contract, and governs draft creation")
System_Ext(source, "Approved package source", "Provides a local JSON curriculum package")

Rel(author, source, "Obtains approved package from")
Rel(author, repofluent, "Uploads package and reads validation evidence")
Rel(reviewer, repofluent, "Acknowledges warnings and reviews checksum")
@enduml
