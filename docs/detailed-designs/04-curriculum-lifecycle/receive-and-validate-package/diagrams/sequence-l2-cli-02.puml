@startuml
title UML sequence behaviour — Intake rejection
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
actor "Curriculum author" as author
box "Frontend — Curriculum workspace" #E0F2FE
  participant "CurriculumPageComponent" as page
  participant "RepoFluentApiService" as client
end box
box "Backend — Curriculum API" #D1FADF
  participant "CurriculumEndpoints" as endpoints
end box
box "Backend — Curriculum Lifecycle Application and Domain" #ECFDF3
  participant "CurriculumWorkflow" as workflow
  participant "PackageIntakeScanner" as scanner
end box
box "Backend — Curriculum Lifecycle Infrastructure" #FFF4E5
  participant "ICurriculumStore" as port
  database "SQLite curriculum store" as store
end box

author -> page : Select unsupported or unsafe content
page -> client : Upload multipart file
client -> endpoints : POST /api/curriculum-imports
endpoints -> workflow : Receive bytes and content metadata
workflow -> workflow : Apply L2-CLI-02 intake rejection gates
alt Unsupported media or configured size
  workflow -> port : Record safe intake-rejected audit
else Executable signature, binary byte, or malformed JSON
  workflow -> scanner : Screen inert bytes
  scanner --> workflow : Stable rejection code
  workflow -> port : Record safe intake-rejected audit
end
port -> store : Append event without rejected content
store --> port : Durable audit result
port --> workflow : Audit recorded
workflow --> endpoints : WorkflowException without import identifier
endpoints --> client : 400 Problem Details and stable code
client --> page : Safe actionable error
page --> author : Present rejection guidance
note over workflow,store
  No CurriculumImport record,
  draft, or learner entity is created.
end note
@enduml
