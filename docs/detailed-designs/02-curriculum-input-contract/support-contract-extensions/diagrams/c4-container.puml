@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Support contract extensions

Person(author, "Curriculum author", "Uploads and inspects curriculum packages")
System_Boundary(repofluent, "RepoFluent") {
  Container(spa, "RepoFluent application", "Angular 21", "Upload, issue, and contract workbench UI")
  Container(api, "RepoFluent API", "ASP.NET Core 10", "Asynchronous curriculum validation and workflow")
  ContainerDb(db, "RepoFluent database", "SQLite", "Tenant-scoped raw packages, state, and validation issues")
}

Rel(author, spa, "Uses", "HTTPS")
Rel(spa, api, "Uploads and polls", "JSON and multipart HTTPS")
Rel(api, db, "Stores packages and issues", "EF Core")
@enduml
