@startuml
title UML sequence behaviour — Extension mechanism
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
skinparam package {
  BorderColor #667085
  FontColor #101828
  BackgroundColor #F9FAFB
}
actor "Curriculum author" as author
box "Frontend — RepoFluent Angular application" #E0F2FE
  participant "CurriculumPageComponent" as page
  participant "RepoFluentApiService" as client
  participant "ContractExtensionPolicyComponent" as workbench
end box
box "Backend — RepoFluent API application" #D1FADF
  participant "CurriculumEndpoints" as endpoints
  participant "CurriculumValidationWorker" as worker
end box
box "Backend — RepoFluent Application and Domain" #ECFDF3
  participant "CurriculumWorkflow" as workflow
  participant "PackageValidator" as validator
end box
box "Backend — RepoFluent Infrastructure" #FFF4E5
  participant "ICurriculumStore" as store
  database "RepoFluent database" as db
end box

author -> page : Upload package with extension
page -> client : Build multipart request
client -> endpoints : POST /api/curriculum-imports
endpoints -> workflow : ReceiveAsync(package bytes)
workflow -> store : AddImportAsync(raw package)
store -> db : Insert received import
db --> store : Stored import
store --> workflow : Receipt state
workflow --> endpoints : ImportReceipt
endpoints --> client : 202 Accepted
client --> page : Receipt
worker -> workflow : ValidateNextAsync
workflow -> store : Claim received import
store -> db : Read and mark validating
db --> store : Raw package
store --> workflow : CurriculumRecord
workflow -> validator : Apply L2-CIC-13
alt Unsupported noncritical extension
  validator --> workflow : Package + CIC_EXTENSION_IGNORED warning
  workflow -> store : Save Draft with preserved raw package
else Unsupported critical extension or core redefinition
  validator --> workflow : Blocking extension issue at exact path
  workflow -> store : Save ValidationFailed
end
store -> db : Persist state and issues
db --> store : Saved result
loop Until validation completes
  page -> client : Request import status
  client -> endpoints : GET /api/curriculum-imports/{id}
  endpoints -> workflow : GetStatusAsync(id)
  workflow -> store : GetImportAsync(id)
  store --> workflow : Status and issues
  workflow --> endpoints : ImportStatus
  endpoints --> client : 200 OK
  client --> page : Typed status
end
page -> workbench : Present accepted extension boundary
workbench --> author : Warning or blocking outcome
@enduml
