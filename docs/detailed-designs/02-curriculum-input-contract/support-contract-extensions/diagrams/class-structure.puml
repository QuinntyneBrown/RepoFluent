@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam class {
  BorderColor #344054
  FontColor #101828
  BackgroundColor #F9FAFB
}
title Class structure — Support contract extensions

class ContractExtension {
  +string Namespace
  +string Version
  +bool? Critical
  +JsonElement Data
}

class Package {
  +string PackageId
  +string Version
  +string Title
  +IReadOnlyList<ContractExtension>? Extensions
}

class PackageValidator {
  +Validate(json: string): (Package?, IReadOnlyList<ValidationIssue>)
  -ValidateExtensions(extensions, issues): void
}

class ValidationIssue {
  +string Code
  +string Severity
  +bool IsBlocking
  +string Message
  +string Path
}

class CurriculumWorkflow {
  +ValidateNextAsync(cancellationToken): Task
}

Package "1" *-- "0..*" ContractExtension : owns
PackageValidator ..> Package : deserializes / validates
PackageValidator ..> ValidationIssue : creates
CurriculumWorkflow ..> PackageValidator : invokes
CurriculumWorkflow --> ValidationIssue : persists outcome
@enduml
