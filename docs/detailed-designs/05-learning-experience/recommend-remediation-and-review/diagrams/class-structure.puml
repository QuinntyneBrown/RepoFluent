@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam class {
  BorderColor #344054
  FontColor #101828
  BackgroundColor #F9FAFB
}
title Class structure — Recommend remediation and review

class RecommendRemediationAndReviewRequest {
  +string ScopeId
  +string ActorId
  +string TargetId
  +long ExpectedVersion
  +string CorrelationId
  +object Payload
}

class RecommendRemediationAndReviewResult {
  +string Outcome
  +long Version
  +string SupportId
}

class RecommendRemediationAndReviewRecord {
  +string Id
  +string TenantId
  +long Version
  +string Status
  +DateTimeOffset UpdatedAt
  +Apply(result: RecommendRemediationAndReviewResult): void
}

class RecommendRemediationAndReviewPolicy {
  +Evaluate(request: RecommendRemediationAndReviewRequest, current: RecommendRemediationAndReviewRecord): RecommendRemediationAndReviewResult
}

interface IRecommendRemediationAndReviewRepository {
  +Load(scopeId: string, targetId: string): Task<RecommendRemediationAndReviewRecord>
  +Save(record: RecommendRemediationAndReviewRecord, expectedVersion: long): Task
}

class RecommendRemediationAndReviewHandler {
  +Handle(request: RecommendRemediationAndReviewRequest): Task<RecommendRemediationAndReviewResult>
}

RecommendRemediationAndReviewHandler ..> RecommendRemediationAndReviewRequest : handles
RecommendRemediationAndReviewHandler ..> RecommendRemediationAndReviewPolicy : invokes
RecommendRemediationAndReviewHandler ..> IRecommendRemediationAndReviewRepository : uses
IRecommendRemediationAndReviewRepository --> RecommendRemediationAndReviewRecord : loads / saves
RecommendRemediationAndReviewPolicy ..> RecommendRemediationAndReviewRecord : evaluates
RecommendRemediationAndReviewPolicy ..> RecommendRemediationAndReviewResult : creates
RecommendRemediationAndReviewRecord ..> RecommendRemediationAndReviewResult : applies
@enduml
