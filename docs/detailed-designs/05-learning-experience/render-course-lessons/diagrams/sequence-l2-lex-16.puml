@startuml
title UML sequence behaviour — Core fallback and accessibility
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
skinparam package {
  BorderColor #667085
  FontColor #101828
  BackgroundColor #F9FAFB
}
actor "Learner" as actor
box "Frontend — Learner application" #E0F2FE
  participant "RenderCourseLessonsPage" as entry
  participant "LearningApiClient" as client
end box
box "Backend — Learning API application" #D1FADF
  participant "RenderCourseLessonsController" as controller
end box
box "Backend — Learning Experience Application and Domain" #ECFDF3
  participant "RenderCourseLessonsHandler" as handler
  participant "RenderCourseLessonsPolicy" as policy
end box
box "Backend — Learning Experience Infrastructure" #FFF4E5
  participant "IRenderCourseLessonsRepository" as repository
  database "Learning record store" as store
end box
actor -> entry : Start render course lessons
entry -> client : Build typed request
client -> controller : Send request with scope and correlation
controller -> controller : Authenticate and apply endpoint policy
controller -> handler : Dispatch RenderCourseLessonsRequest
handler -> repository : Load authorized current state
repository -> store : Read tenant-scoped record
store --> repository : Current record
repository --> handler : Authorized state
handler -> policy : Apply L2-LEX-16
alt Policy and validation accept the request
  policy --> handler : Typed accepted result
  handler -> repository : Save with expected version and idempotency key
  repository -> store : Commit one result
  store --> repository : Durable version
  repository --> handler : Commit result
  handler --> controller : Typed feature result
else Policy or validation rejects the request
  policy --> handler : Typed rejection without mutation
  handler --> controller : Safe failure result
end
controller --> client : HTTP response or Problem Details
client --> entry : Typed outcome
entry --> actor : Present accessible feature state
@enduml
