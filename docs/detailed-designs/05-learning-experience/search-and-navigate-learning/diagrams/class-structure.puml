}

class SearchAndNavigateLearningPolicy {
  +Evaluate(request: SearchAndNavigateLearningRequest, current: SearchAndNavigateLearningRecord): SearchAndNavigateLearningResult
}

interface ISearchAndNavigateLearningRepository {
  +Load(scopeId: string, targetId: string): Task<SearchAndNavigateLearningRecord>
  +Save(record: SearchAndNavigateLearningRecord, expectedVersion: long): Task
}

class SearchAndNavigateLearningHandler {
  +Handle(request: SearchAndNavigateLearningRequest): Task<SearchAndNavigateLearningResult>
}

SearchAndNavigateLearningHandler ..> SearchAndNavigateLearningRequest : handles
