}
title Class structure — Search and navigate learning

class SearchAndNavigateLearningRequest {
  +string ScopeId
  +string ActorId
  +string TargetId
  +long ExpectedVersion
  +string CorrelationId
  +object Payload
}

class SearchAndNavigateLearningResult {
  +string Outcome
  +long Version
  +string SupportId
}

class SearchAndNavigateLearningRecord {
  +string Id
  +string TenantId
